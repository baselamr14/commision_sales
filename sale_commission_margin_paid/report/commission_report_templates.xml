<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_commission_report_pdf">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>Commission Report</h2>

                    <table class="table table-sm table-bordered mb-3">
                        <tbody>
                            <tr>
                                <td><strong>Start Date</strong></td>
                                <td><span t-esc="docs.date_from"/></td>
                                <td><strong>End Date</strong></td>
                                <td><span t-esc="docs.date_to"/></td>
                            </tr>
                            <tr>
                                <td><strong>Salesperson</strong></td>
                                <td><span t-esc="docs.salesperson_id.name or ''"/></td>
                                <td><strong>Customer</strong></td>
                                <td><span t-esc="docs.customer_id.name or ''"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Salesperson</th>
                                <th>Customer</th>
                                <th>Target Name</th>
                                <th class="text-end">Achieved</th>
                                <th>Currency</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="total" t-value="0.0"/>
                            <tr t-foreach="lines" t-as="line">
                                <t t-set="total" t-value="total + (line.achieved or 0.0)"/>
                                <td><span t-esc="line.date"/></td>
                                <td><span t-esc="line.user_id.name"/></td>
                                <td><span t-esc="line.partner_id.name"/></td>
                                <td><span t-esc="line.target_id.display_name"/></td>
                                <td class="text-end">
                                    <span t-esc="line.achieved"/>
                                </td>
                                <td><span t-esc="line.currency_id.name"/></td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4"><strong>Total</strong></td>
                                <td class="text-end">
                                    <strong t-esc="total"/>
                                </td>
                                <td/>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
