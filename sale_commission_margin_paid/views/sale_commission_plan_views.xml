<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit Commission Plan form -->
    <record id="view_sale_commission_plan_form_inherit_margin" model="ir.ui.view">
        <field name="name">sale.commission.plan.form.margin</field>
        <field name="model">sale.commission.plan</field>
        <field name="inherit_id" ref="sale_commission.sale_commission_plan_form_view"/>
        <field name="arch" type="xml">

            <!-- Add Commission % inside Achievements tab -->
            <xpath expr="//field[@name='achievement_ids']/tree/field[@name='type']" position="after">
                <field name="commission_rate"/>
            </xpath>

        </field>
    </record>

</odoo>
 <!-- <?xml version="1.0" encoding="utf-8"?>
<odoo>
    
        No view overrides needed.
        The new 'margin_paid' selection option is injected entirely via
        the Python selection_add in the model, so it appears automatically
        in the Type dropdown on the Achievements tab of the commission plan
        form without any XML change.
    
</odoo>  -->
