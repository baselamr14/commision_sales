<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sale_commission_create_bill_wizard_form" model="ir.ui.view">
        <field name="name">sale.commission.create.bill.wizard.form</field>
        <field name="model">sale.commission.create.bill.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Commission Invoice">
                <group string="Filters" col="2">
                    <field name="salesperson_id" readonly="1"/>
                    <field name="commission_product_id"/>
                    <field name="date_from" readonly="1"/>
                    <field name="journal_id"/>
                    <field name="date_to" readonly="1"/>
                    <field name="bill_date"/>
                    <field name="partner_id" readonly="1"/>
                    <field name="currency_id" invisible="1"/>
                </group>

                <separator string="Commission Lines To Invoice"/>

                <field name="line_ids" nolabel="1">
                    <list create="0" delete="0">
                        <field name="selected"/>
                        <field name="display_name" string="Reference" readonly="1"/>
                        <field name="source_invoice_id" string="Invoice" readonly="1"/>
                        <field name="customer_id" string="Customer" readonly="1"/>
                        <field name="date" readonly="1"/>
                        <field name="commission_amount" readonly="1"/>
                    </list>
                </field>

                <group>
                    <field name="total_amount" readonly="1"/>
                </group>

                <footer>
                    <button name="action_create_vendor_bill"
                            string="Create Vendor Bill"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sale_commission_create_bill_wizard" model="ir.actions.act_window">
        <field name="name">Create Vendor Bill</field>
        <field name="res_model">sale.commission.create.bill.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="sale_commission.model_sale_commission_achievement_report"/>
        <field name="binding_type">action</field>
        <field name="binding_view_types">list</field>
    </record>

</odoo>