<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_commission_invoice_wizard_form" model="ir.ui.view">
        <field name="name">commission.invoice.wizard.form</field>
        <field name="model">commission.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Commission Invoice">
                <group string="Filters">
                    <group>
                        <field name="salesperson_id"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="product_id"/>
                        <field name="journal_id"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </group>
                <group string="Commission Lines to Invoice">
                    <field name="commission_line_ids" nolabel="1">
                        <list create="false" edit="false" delete="false">
                            <field name="name"/>
                            <field name="date"/>
                            <field name="invoice_id"/>
                            <field name="rule_id"/>
                            <field name="commission_type"/>
                            <field name="commission_amount" sum="Total"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>
                </group>
                <group>
                    <field name="total_commission" widget="monetary"/>
                </group>
                <footer>
                    <button name="action_create_invoice" string="Create Vendor Bill"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Standalone action to open wizard -->
    <record id="action_commission_invoice_wizard" model="ir.actions.act_window">
        <field name="name">Create Commission Invoice</field>
        <field name="res_model">commission.invoice.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
