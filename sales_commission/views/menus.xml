<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Top-level Commission menu under Sales -->
    <menuitem id="menu_commission_root"
              name="Commissions"
              parent="sale.sale_menu_root"
              sequence="25"/>

    <!-- Commission Lines -->
    <menuitem id="menu_commission_line"
              name="Commission Lines"
              parent="menu_commission_root"
              action="action_commission_line"
              sequence="10"/>

    <!-- My Commissions (for salesperson) -->
    <menuitem id="menu_my_commission_line"
              name="My Commissions"
              parent="menu_commission_root"
              action="action_my_commission_line"
              sequence="15"
              groups="sales_team.group_sale_salesman"/>

    <!-- Commission Rules -->
    <menuitem id="menu_commission_rule"
              name="Commission Rules"
              parent="menu_commission_root"
              action="action_commission_rule"
              sequence="20"
              groups="sales_team.group_sale_manager"/>

    <!-- Create Invoice Wizard -->
    <menuitem id="menu_commission_invoice_wizard"
              name="Create Commission Invoice"
              parent="menu_commission_root"
              action="action_commission_invoice_wizard"
              sequence="30"
              groups="sales_team.group_sale_manager"/>

    <!-- Analysis / Reporting -->
    <menuitem id="menu_commission_analysis"
              name="Commission Analysis"
              parent="menu_commission_root"
              action="action_commission_report"
              sequence="40"
              groups="sales_team.group_sale_manager"/>

</odoo>
