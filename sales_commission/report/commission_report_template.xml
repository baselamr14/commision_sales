<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Commission Lines Report (detailed, per salesperson)
    ============================================================ -->
    <template id="report_commission_lines_document">
        <t t-call="web.external_layout">
            <div class="page">
                <div class="row mb-4">
                    <div class="col-6">
                        <h2>Commission Report</h2>
                        <p class="text-muted mb-0">
                            <t t-esc="docs[0].salesperson_id.name if docs else ''"/>
                        </p>
                    </div>
                    <div class="col-6 text-end">
                        <p class="mb-0">
                            <strong>Date Range:</strong>
                            <t t-if="date_from and date_to">
                                <t t-esc="date_from"/> – <t t-esc="date_to"/>
                            </t>
                            <t t-else="">All dates</t>
                        </p>
                        <p class="mb-0">
                            <strong>Printed:</strong>
                            <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                        </p>
                    </div>
                </div>

                <table class="table table-sm table-bordered o_main_table">
                    <thead>
                        <tr style="background-color:#f5f5f5;">
                            <th>Reference</th>
                            <th>Date</th>
                            <th>Salesperson</th>
                            <th>Customer</th>
                            <th>Invoice</th>
                            <th>Rule</th>
                            <th>Type</th>
                            <th class="text-end">Base Amount</th>
                            <th class="text-end">Commission</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="docs" t-as="line">
                            <tr>
                                <td><t t-esc="line.name"/></td>
                                <td><t t-esc="line.date" t-options="{'widget': 'date'}"/></td>
                                <td><t t-esc="line.salesperson_id.name"/></td>
                                <td><t t-esc="line.invoice_id.partner_id.name"/></td>
                                <td><t t-esc="line.invoice_id.name"/></td>
                                <td><t t-esc="line.rule_id.name"/></td>
                                <td><span t-field="line.commission_type"/></td>
                                <td class="text-end">
                                    <t t-esc="line.base_amount"
                                       t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"/>
                                </td>
                                <td class="text-end">
                                    <t t-esc="line.commission_amount"
                                       t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"/>
                                </td>
                                <td>
                                    <span t-attf-class="badge #{
                                        'text-bg-info' if line.state == 'draft' else
                                        'text-bg-success' if line.state == 'confirmed' else
                                        'text-bg-warning' if line.state == 'invoiced' else
                                        'text-bg-danger'}">
                                        <t t-esc="dict(line._fields['state'].selection).get(line.state, '')"/>
                                    </span>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="8" class="text-end"><strong>Total Commission:</strong></td>
                            <td class="text-end">
                                <strong>
                                    <t t-esc="sum(docs.mapped('commission_amount'))"
                                       t-options="{'widget': 'monetary', 'display_currency': docs[0].currency_id if docs else env.company.currency_id}"/>
                                </strong>
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </t>
    </template>

<template id="report_commission_lines">
    <t t-call="web.html_container">
        <t t-call="sales_commission.report_commission_lines_document"/>
    </t>
</template>
    <template id="report_commission_lines">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="sales_commission.report_commission_lines_document"
                   t-lang="doc.salesperson_id.lang"/>
            </t>
        </t>
    </template>

    <!-- ============================================================
         Commission Summary Report (grouped by salesperson)
    ============================================================ -->
    <template id="report_commission_summary_document">
        <t t-call="web.external_layout">
            <div class="page">
                <div class="row mb-4">
                    <div class="col-6">
                        <h2>Commission Summary</h2>
                    </div>
                    <div class="col-6 text-end">
                        <p class="mb-0">
                            <strong>Date Range:</strong>
                            <t t-esc="date_from or 'All'"/> – <t t-esc="date_to or 'All'"/>
                        </p>
                        <p class="mb-0">
                            <strong>Printed:</strong>
                            <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                        </p>
                    </div>
                </div>

                <t t-foreach="grouped_data" t-as="group">
                    <h4 class="mt-4"><t t-esc="group['salesperson']"/></h4>
                    <table class="table table-sm table-bordered o_main_table">
                        <thead>
                            <tr style="background-color:#f5f5f5;">
                                <th>Reference</th>
                                <th>Date</th>
                                <th>Invoice</th>
                                <th>Customer</th>
                                <th>Type</th>
                                <th class="text-end">Commission</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="group['lines']" t-as="line">
                                <tr>
                                    <td><t t-esc="line.name"/></td>
                                    <td><t t-esc="line.date" t-options="{'widget': 'date'}"/></td>
                                    <td><t t-esc="line.invoice_id.name"/></td>
                                    <td><t t-esc="line.invoice_id.partner_id.name"/></td>
                                    <td><span t-field="line.commission_type"/></td>

                                    <td class="text-end">
                                        <t t-esc="line.commission_amount"
                                           t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"/>
                                    </td>
                                    <td>
                                        <span t-attf-class="badge #{
                                            'text-bg-info' if line.state == 'draft' else
                                            'text-bg-success' if line.state == 'confirmed' else
                                            'text-bg-warning' if line.state == 'invoiced' else
                                            'text-bg-danger'}">
                                            <t t-esc="dict(line._fields['state'].selection).get(line.state, '')"/>
                                        </span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="5" class="text-end"><strong>Subtotal:</strong></td>
                                <td class="text-end">
                                    <strong>
                                        <t t-esc="group['total']"
                                           t-options="{'widget': 'monetary', 'display_currency': group['lines'][0].currency_id if group['lines'] else env.company.currency_id}"/>
                                    </strong>
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </t>

                <!-- Grand Total -->
                <div class="row mt-4">
                    <div class="col-12 text-end">
                        <h4>Grand Total:
                            <t t-esc="grand_total"
                               t-options="{'widget': 'monetary', 'display_currency': env.company.currency_id}"/>
                        </h4>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="report_commission_summary">
        <t t-call="web.html_container">
            <t t-call="sales_commission.report_commission_summary_document"/>
        </t>
    </template>

    <!-- ============================================================
         Report Actions
    ============================================================ -->
    <record id="action_report_commission_lines" model="ir.actions.report">
        <field name="name">Commission Report</field>
        <field name="model">commission.line</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sales_commission.report_commission_lines</field>
        <field name="report_file">sales_commission.report_commission_lines</field>
        <field name="binding_model_id" ref="model_commission_line"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

</odoo>
