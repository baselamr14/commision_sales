<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence for commission lines -->
    <record id="seq_commission_line" model="ir.sequence">
        <field name="name">Commission Line</field>
        <field name="code">commission.line</field>
        <field name="prefix">COM/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Default commission service product -->
    <record id="product_commission_service" model="product.product">
        <field name="name">Sales Commission</field>
        <field name="type">service</field>
        <field name="sale_ok" eval="False"/>
        <field name="purchase_ok" eval="True"/>
        <field name="description_pickingout">Sales Commission Payment</field>
    </record>
</odoo>
