<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lead_form_geolocation_inherit" model="ir.ui.view">
        <field name="name">crm.lead.form.geolocation.inherit</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- Add location block near the address fields -->
            <xpath expr="//field[@name='street']" position="after">
                <field name="geo_map_url" widget="url" readonly="1"/>
            </xpath>

            <xpath expr="//sheet//group" position="inside">
                <group string="GPS Location">
                    <field name="geo_latitude" readonly="1"/>
                    <field name="geo_longitude" readonly="1"/>
                    <field name="geo_accuracy" readonly="1"/>
                    <field name="geo_location_fetched_at" readonly="1"/>
                    <field name="name" widget="geo_location_button" nolabel="1"/>
                </group>
            </xpath>

        </field>
    </record>
</odoo>