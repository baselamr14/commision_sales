<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_report_pivot_inherit_profit_commission" model="ir.ui.view">
        <field name="name">sale.report.pivot.inherit.profit.commission</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.view_order_product_pivot"/>
        <field name="arch" type="xml">
            <xpath expr="//pivot" position="inside">
                <field name="purchase_cost" type="measure"/>
                <field name="cost_total" type="measure"/>
                <field name="profit_amount" type="measure"/>
                <field name="commission_amount" type="measure"/>
            </xpath>
        </field>
    </record>

    <record id="view_sale_report_graph_inherit_profit_commission" model="ir.ui.view">
        <field name="name">sale.report.graph.inherit.profit.commission</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.view_order_product_graph"/>
        <field name="arch" type="xml">
            <xpath expr="//graph" position="inside">
                <field name="purchase_cost" type="measure"/>
                <field name="cost_total" type="measure"/>
                <field name="profit_amount" type="measure"/>
                <field name="commission_amount" type="measure"/>
            </xpath>
        </field>
    </record>
</odoo>