<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_profit_commission" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.profit.commission</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Add total commission in totals area -->
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="total_commission" readonly="1"/>
            </xpath>

            <!-- Add fields to the order line list view -->
            <xpath expr="//field[@name='order_line']/list//field[@name='price_unit']" position="after">
                <field name="purchase_cost" optional="show"/>
                <field name="commission_percent" optional="show"/>
                <field name="profit_amount" readonly="1" optional="show"/>
                <field name="commission_amount" readonly="1" optional="show"/>
            </xpath>

            <!-- Add fields to the order line form view -->
            <xpath expr="//field[@name='order_line']/form//field[@name='price_unit']" position="after">
                <field name="purchase_cost"/>
                <field name="commission_percent"/>
                <field name="profit_amount" readonly="1"/>
                <field name="commission_amount" readonly="1"/>
            </xpath>

        </field>
    </record>
</odoo>
